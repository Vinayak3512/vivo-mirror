NEXT_PUBLIC_API_BASE_URL=http://localhost:5056
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:5056/graphql
# Set to true to disable auth guard and access all pages without login.
# All current pages use mock data and don't call the backend, so this can
# stay true until the .NET backend is running and wired up.
NEXT_PUBLIC_DISABLE_AUTH=true
